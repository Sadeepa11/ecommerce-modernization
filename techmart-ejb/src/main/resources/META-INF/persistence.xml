<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
    <persistence-unit name="TechMartPU" transaction-type="JTA">
        <jta-data-source>java:app/jdbc/TechMartDS</jta-data-source>
        
        <properties>
            <!-- Hibernate dialect for MySQL (common for WildFly/GlassFish) -->
            <property name="jakarta.persistence.schema-generation.database.action" value="drop-and-create"/>
            <property name="eclipselink.ddl-generation" value="drop-and-create-tables"/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            
            <!-- Connection pooling optimization configurations -->
            <property name="hibernate.connection.release_mode" value="auto"/>
        </properties>
    </persistence-unit>
</persistence>
